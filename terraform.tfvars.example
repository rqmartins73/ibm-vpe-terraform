##############################################################################
# IBM Cloud Authentication
##############################################################################

# Your IBM Cloud API Key
# Get it from: https://cloud.ibm.com/iam/apikeys
ibmcloud_api_key = "YOUR_IBM_CLOUD_API_KEY_HERE"

# IBM Cloud region where VPE resources will be created
# Options: us-south, us-east, eu-gb, eu-de, jp-tok, au-syd, etc.
region = "us-south"

# Resource Group ID where VPE resources will be created
# Get it with: ibmcloud resource groups --output json | jq -r '.[] | "\(.name): \(.id)"'
resource_group_id = "your-resource-group-id-here"

##############################################################################
# VPE Configurations
##############################################################################

# Example 1: Single VPE for Cloud Object Storage
vpe_configurations = [
  {
    name       = "cos-vpe"
    vpc_id     = "r006-12345678-1234-1234-1234-123456789012"
    subnet_ids = ["0717-12345678-1234-1234-1234-123456789012"]
    target_crn = "crn:v1:bluemix:public:cloud-object-storage:global:::endpoint:s3.direct.us-south.cloud-object-storage.appdomain.cloud"
    tags       = ["env:prod", "service:cos"]
  }
]

# Example 2: Multiple VPEs across different services and zones
# vpe_configurations = [
#   {
#     name       = "cos-vpe-multizone"
#     vpc_id     = "r006-vpc-id-1"
#     subnet_ids = [
#       "0717-subnet-zone1-id",
#       "0717-subnet-zone2-id",
#       "0717-subnet-zone3-id"
#     ]
#     target_crn         = "crn:v1:bluemix:public:cloud-object-storage:global:::endpoint:s3.direct.us-south.cloud-object-storage.appdomain.cloud"
#     security_group_ids = ["r006-sg-id-1", "r006-sg-id-2"]
#     tags               = ["env:prod", "service:cos", "ha:enabled"]
#   },
#   {
#     name       = "kms-vpe"
#     vpc_id     = "r006-vpc-id-1"
#     subnet_ids = ["0717-subnet-zone1-id"]
#     target_crn = "crn:v1:bluemix:public:kms:us-south:::endpoint:private.us-south.kms.cloud.ibm.com"
#     tags       = ["env:prod", "service:kms"]
#   },
#   {
#     name               = "postgres-vpe"
#     vpc_id             = "r006-vpc-id-2"
#     subnet_ids         = ["0717-subnet-zone2-id"]
#     target_crn         = "crn:v1:bluemix:public:databases-for-postgresql:us-south:::endpoint:private.us-south.databases.appdomain.cloud"
#     security_group_ids = ["r006-sg-id-3"]
