# PostgreSQL: crn:v1:bluemix:public:databases-for-postgresql:eu-gb:::endpoint:private.eu-gb.databases.appdomain.cloud
# Container Registry: crn:v1:bluemix:public:container-registry:eu-gb:::endpoint:private.uk.icr.io

# EU-DE (Frankfurt)
